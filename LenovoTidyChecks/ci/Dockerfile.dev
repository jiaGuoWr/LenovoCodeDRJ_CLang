# Development container for LenovoTidyChecks contributors.
# Usage:
#   docker build -t lenovo-tidy-dev -f ci/Dockerfile.dev .
#   docker run --rm -it -v "$PWD:/workspace" -w /workspace lenovo-tidy-dev bash

FROM ubuntu:22.04

ENV DEBIAN_FRONTEND=noninteractive \
    TZ=Etc/UTC

RUN apt update && apt install -y --no-install-recommends \
        ca-certificates gnupg lsb-release wget software-properties-common \
        git build-essential \
        cmake ninja-build \
        python3 python3-pip \
    && wget -qO- https://apt.llvm.org/llvm-snapshot.gpg.key | apt-key add - \
    && add-apt-repository "deb http://apt.llvm.org/jammy/ llvm-toolchain-jammy-18 main" \
    && apt update \
    && apt install -y --no-install-recommends \
        llvm-18-dev libclang-18-dev libclang-cpp18-dev \
        clang-18 clang-tools-18 clang-tidy-18 clang-format-18 \
    && pip3 install --no-cache-dir lit mkdocs mkdocs-material pymdown-extensions \
    && rm -rf /var/lib/apt/lists/*

ENV CC=clang-18 \
    CXX=clang++-18 \
    PATH=/usr/lib/llvm-18/bin:${PATH}

WORKDIR /workspace

CMD ["bash"]
