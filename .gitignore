# ============================================================================
#  Lenovo DRJ C-Lang - root .gitignore
#  Keeps per-component .gitignore files as the source of truth for each
#  sub-project; this file adds repo-wide rules for build output, test code
#  (explicitly requested to be excluded), distribution artefacts, IDE
#  scratch, and OS cruft.
# ============================================================================

# ---------------------- Build output (all components) -----------------------
# Rust
target/
**/target/
*.rs.bk
Cargo.lock.bak

# C# / VS extension
bin/
obj/
*.vsix
server-bin/
.vs/

# C++ / CMake
build/
cmake-build-*/
out/
CMakeUserPresets.json
CMakeCache.txt
CMakeFiles/
compile_commands.json
*.o
*.obj
*.a
*.lib
*.so
*.so.*
*.dylib
*.dll
*.exe
*.pdb
*.ilk
*.exp
*.suo
*.user

# Node.js
node_modules/
*.tsbuildinfo
npm-debug.log*
yarn-debug.log*

# Python (lit tests etc)
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/

# ---------------------- Test code (per user request) -----------------------
# Integration + unit tests that live in dedicated sub-folders. Embedded
# `#[cfg(test)]` blocks inside Rust source files are not separable and
# remain in the committed source.
LenovoTidyLsp/tests/
LenovoTidyChecks/tests/

# ---------------------- Distribution artefacts -----------------------------
# The dist/ folder holds ~250 MB of compiled VSIX + lenovo-clang-tidy.exe.
# These are all reproducible via the windows-build/*.ps1 scripts.
dist/

# ---------------------- Build/diagnostics transient state ------------------
windows-build/logs/
windows-build/downloads/

# Per-session smoke-activate logs that end up in %TEMP% already, but guard
# against anyone copying one into the repo by accident.
lenovo-activity-*.xml
lenovo-vsix-*.zip

# ---------------------- IDE / editor scratch -------------------------------
.idea/
.vscode/
.vs/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# Cursor workspace state (if any)
.cursor/

# ---------------------- Secrets / credentials (defence in depth) -----------
*.pem
*.pfx
*.key
*.crt
.env
.env.*
!.env.example
