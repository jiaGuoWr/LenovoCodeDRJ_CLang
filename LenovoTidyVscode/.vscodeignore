.vscode-test/**
src/**
.gitignore
.yarnrc
vsc-extension-quickstart.md
**/tsconfig.json
**/.eslintrc.json
**/*.map
**/*.ts
# NOTE: do NOT exclude node_modules/** - vsce automatically packs only the
# runtime `dependencies` from package.json (vscode-languageclient and its
# transitive deps). Excluding the whole tree causes
# "Cannot find module 'vscode-languageclient/node'" at activate() time.
